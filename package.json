{
  "name": "celina-mcp-host",
  "version": "0.1.9",
  "private": true,
  "description": "Vercel-hosted read-only Streamable HTTP endpoint for @andrewkimjoseph/celina-mcp",
  "type": "module",
  "scripts": {
    "build": "echo \"celina-mcp is prebuilt via npm install\"",
    "dev": "vercel dev",
    "test:smoke": "npx tsx scripts/smoke-test.ts"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@andrewkimjoseph/celina-mcp": "0.8.6",
    "@andrewkimjoseph/celina-sdk": "0.4.9",
    "@mento-protocol/mento-sdk": "^3.2.8",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@uniswap/sdk-core": "^7.16.1",
    "@uniswap/universal-router-sdk": "^5.5.1",
    "@uniswap/v4-sdk": "^2.2.1"
  },
  "overrides": {
    "@andrewkimjoseph/celina-mcp": {
      "@andrewkimjoseph/celina-sdk": "$@andrewkimjoseph/celina-sdk"
    }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.8.2"
  }
}
