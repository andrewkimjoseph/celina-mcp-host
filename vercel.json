{
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "functions": {
    "api/mcp.ts": {
      "maxDuration": 30,
      "memory": 1024
    },
    "api/a2a.ts": {
      "maxDuration": 30,
      "memory": 1024
    }
  },
  "rewrites": [
    {
      "source": "/mcp",
      "destination": "/api/mcp"
    },
    {
      "source": "/a2a",
      "destination": "/api/a2a"
    }
  ]
}
